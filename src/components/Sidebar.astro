---
import { books, getBook } from "../data/books";
import { l } from "../data/labels";

interface Props {
  currentSlug?: string;
  bookSlug?: string;
}

const { currentSlug, bookSlug } = Astro.props;
const book = bookSlug ? getBook(bookSlug) : books[0];
---

<nav>
  <a href="/" class="home-link">{l("nav.home")}</a>

  <a
    href={`/${book.slug}`}
    class:list={["book-title", { active: currentSlug === book.slug }]}
  >
    {book.title}
  </a>

  {book.parts.map((part) => (
    <div class="part">
      <span class="part-label">{part.title}</span>
      <ul>
        {part.chapters.map((ch) => (
          <li>
            <a
              href={`/${book.slug}/${ch.slug}`}
              class:list={[{ active: currentSlug === ch.slug }]}
            >
              <span class="dot" />
              <span class="ch-title">{ch.number}. {ch.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>

<style>
  nav {
    font-size: 0.8rem;
  }

  .home-link {
    display: block;
    padding: 0.4rem 1.25rem;
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .home-link:hover {
    color: var(--text);
  }

  .book-title {
    display: block;
    padding: 0.4rem 1.25rem;
    font-weight: 700;
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }

  .book-title.active {
    color: var(--accent);
  }

  .part {
    margin-bottom: 1rem;
  }

  .part-label {
    display: block;
    padding: 0 1.25rem;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  ul {
    list-style: none;
  }

  li a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 1.25rem;
    color: var(--text-muted);
    transition: color 0.1s, background 0.1s;
  }

  li a:hover {
    color: var(--text);
    background: var(--border);
  }

  li a.active {
    color: var(--accent);
    background: var(--accent-bg);
  }

  .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--text-muted);
  }

  .ch-title {
    line-height: 1.3;
  }
</style>
