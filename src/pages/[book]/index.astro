---
import WikiLayout from "../../layouts/WikiLayout.astro";
import { books, getBook } from "../../data/books";
import { l } from "../../data/labels";

export function getStaticPaths() {
  return books.map((b) => ({ params: { book: b.slug } }));
}

const { book: bookSlug } = Astro.params;
const book = getBook(bookSlug!);
---

<WikiLayout title={book.title} currentSlug={book.slug} bookSlug={bookSlug}>
  <h1>{book.title}</h1>
  <p class="subtitle">{book.author}{book.translator ? ` · ${book.translator}` : ""} · {book.publisher} · {book.publishedAt}</p>

  {book.parts.map((part) => (
    <section>
      <h2>{part.title}</h2>
      <ul>
        {part.chapters.map((ch) => (
          <li>
            <a href={`/${book.slug}/${ch.slug}`}>
              <span class="num">{ch.number}</span>
              <span class="title">{ch.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</WikiLayout>

<style>
  h1 {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .subtitle {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
    margin-bottom: 2.5rem;
  }

  section {
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  ul {
    list-style: none;
  }

  li a {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.85rem;
    transition: color 0.1s;
  }

  li a:hover {
    color: var(--accent);
  }

  .num {
    font-size: 0.75rem;
    color: var(--text-muted);
    min-width: 1.5rem;
  }

  .title {
    flex: 1;
  }
</style>
