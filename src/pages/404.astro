---
import Layout from "../layouts/Layout.astro";
import { l } from "../data/labels";
---

<Layout title={l("404.title")}>
  <div class="not-found">
    <h1>404</h1>
    <p>{l("404.description")}</p>
    <a href="/">{l("404.home")}</a>
  </div>
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    text-align: center;
    gap: 0.5rem;
  }

  h1 {
    font-size: 4rem;
    font-weight: 800;
    color: var(--text-muted);
  }

  p {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  a {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--accent);
  }

  a:hover {
    text-decoration: underline;
  }
</style>
